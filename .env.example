# ============================================================================
# linkedin-ai-apply configuration
# Copy this file to ".env" and edit. Everything here can also be set in
# config.yaml; .env values win. CLI flags win over both.
# ============================================================================

# ---- Submission policy (the "auto-approve" control) ------------------------
# auto      = seamless. Auto-submit Easy Apply AND let the AI attempt
#             external/portal/post applications. Only fall back to
#             human_review when the AI is genuinely blocked.
# easy_only = auto-submit Easy Apply; send all external to human_review.
# review    = never submit; just draft + queue everything for you.
SUBMIT_MODE=auto

# If true, fill every form but NEVER click the final submit button.
DRY_RUN=false

# ---- Matching / volume -----------------------------------------------------
MATCH_THRESHOLD=70
MAX_APPLIES_PER_RUN=20
MIN_DELAY_MS=1200
MAX_DELAY_MS=4200

# ---- Browser ---------------------------------------------------------------
HEADLESS=false
# persistent  = you log in manually once; session reused (recommended).
# credentials = auto-login from LINKEDIN_EMAIL/PASSWORD below (pauses for 2FA).
LOGIN_MODE=persistent
BROWSER_PROFILE_DIR=browser_profile

# ---- Reuse YOUR real Chrome (so it's already logged in) --------------------
# Use your installed Chrome (real binary) instead of the bundled Chromium. The
# tool launches Chrome itself against a dedicated copy of your profile (seeded
# once from your real profile) and drives it over CDP. A copy is required
# because Chrome 136+ refuses remote debugging on your live/default profile dir.
# Quit Chrome before the first run so the copy can be made cleanly.
USE_SYSTEM_CHROME=false
BROWSER_CHANNEL=chrome
# Source profile to seed from (defaults shown; use Windows path on Windows):
CHROME_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
# Windows example:
# CHROME_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\User Data
CHROME_PROFILE_DIRECTORY=Default
CHROME_REMOTE_PORT=9222
CHROME_BINARY=
#
# Alternative: attach to a Chrome you started yourself with remote debugging on
# a NON-default user-data-dir. If set, takes precedence over USE_SYSTEM_CHROME.
CDP_URL=

# Only used when LOGIN_MODE=credentials.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ---- LLM (pluggable via litellm) -------------------------------------------
# Examples (LLM_MODEL):
#   openai/gpt-4o-mini
#   anthropic/claude-3-5-sonnet-latest
#   gemini/gemini-1.5-pro
#   openrouter/openai/gpt-4o-mini   (OpenRouter; key starts with sk-or-...)
#   ollama/llama3.2                 (local, no key)
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.4

# RECOMMENDED: one universal key used for every LLM call regardless of provider.
# (Takes precedence over the provider-specific keys below.)
LLM_API_KEY=

# Provider-specific keys (only used if LLM_API_KEY is empty):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# For ollama / custom OpenAI-compatible endpoints:
LLM_API_BASE=

# ---- Discovery -------------------------------------------------------------
ENABLE_HIRING_POSTS=true

# ---- Documents -------------------------------------------------------------
# pdf or docx
RESUME_OUTPUT_FORMAT=pdf

# ---- Paths (relative to project root unless absolute) ----------------------
DB_PATH=data/state.db
SHEET_PATH=data/jobs.xlsx
MASTER_RESUME_PATH=profile/master_resume.docx
INTAKE_PATH=profile/intake.yaml
# Answers you supply via `linkedin-apply review` are stored here and merged into
# your screening answers on the next run (so the agent learns them for all jobs).
LEARNED_ANSWERS_PATH=profile/learned_answers.yaml
OUTPUT_DIR=output
